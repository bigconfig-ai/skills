(ns __PKG_NAMESPACE__.package-test
  (:require
   [clojure.java.io :as io]
   [clojure.java.shell :refer [sh]]
   [clojure.string :as str]
   [clojure.test :refer [deftest is]]
   [__PKG_NAMESPACE__.validation :as validation]))

(def ^:private profile
  {:big-config.render/profile "__PKG_NAME__"
   :big-config.workflow/params {:package "__PKG_NAME__" :name "world"}})

(deftest validate-report-passes-for-complete-profile
  (is (:ok? (validation/validate-report profile {}))))

(deftest validate-report-flags-blank-or-placeholder-param
  (let [result (validation/validate-report profile {"BC_PAR_NAME" "REPLACE_ME"})]
    (is (not (:ok? result)))
    (is (some #(str/includes? (:detail %) "name") (:errors result)))))

(defn- find-file
  [dir name]
  (->> (file-seq (io/file dir))
       (filter #(and (.isFile %) (= name (.getName %))))
       first))

(defn- delete-tree!
  [f]
  (when (.exists (io/file f))
    (run! io/delete-file (reverse (file-seq (io/file f))))))

(defn- top-level-dist-dir
  [dist]
  (let [dirs (->> (seq (.listFiles (io/file dist)))
                  (filter #(.isDirectory %))
                  (sort-by #(.getName %)))]
    (is (= 1 (count dirs)) "exactly one top-level .dist directory should be rendered")
    (first dirs)))

(defn- assert-greeting-rendered
  ([dir]
   (assert-greeting-rendered dir "Hello, world!"))
  ([dir expected]
   (let [greeting (when dir (find-file dir "greeting.txt"))]
     (is (some? greeting) "greeting.txt should be rendered under .dist")
     (when greeting
       (is (str/includes? (slurp greeting) expected))))))

(defn- run-package
  ([pkg-dir step]
   (sh "bb" "run" "package" step :dir pkg-dir))
  ([pkg-dir step env]
   (sh "bb" "run" "package" step :dir pkg-dir :env env)))

(defn- run-hello-render
  ([pkg-dir]
   (sh "bb" "run" "hello" "render" :dir pkg-dir))
  ([pkg-dir env]
   (sh "bb" "run" "hello" "render" :dir pkg-dir :env env)))

(deftest package-lifecycle-validate-describe-delete
  (let [pkg-dir (System/getProperty "user.dir")]
    (doseq [step ["validate" "describe" "delete"]]
      (let [{:keys [exit out err]} (run-package pkg-dir step)]
        (is (zero? exit) (str step " failed\n" out "\n" err))))))

(deftest package-build-and-create-render-hello-template
  (let [pkg-dir (System/getProperty "user.dir")
        dist (io/file pkg-dir ".dist")]
    (doseq [step ["build" "create"]]
      (try
        (delete-tree! dist)
        (let [{:keys [exit out err]} (run-package pkg-dir step)]
          (is (zero? exit) (str step " failed\n" out "\n" err))
          (assert-greeting-rendered (top-level-dist-dir dist)))
        (finally
          (delete-tree! dist))))))

(deftest hello-render-uses-package-build-top-level-dist-dir
  (let [pkg-dir (System/getProperty "user.dir")
        dist (io/file pkg-dir ".dist")]
    (try
      (delete-tree! dist)
      (let [{build-exit :exit build-out :out build-err :err} (run-package pkg-dir "build")]
        (is (zero? build-exit) (str "package build failed\n" build-out "\n" build-err))
        (let [build-dir (top-level-dist-dir dist)
              build-name (some-> build-dir .getName)]
          (assert-greeting-rendered build-dir)
          (delete-tree! dist)
          (let [{hello-exit :exit hello-out :out hello-err :err} (run-hello-render pkg-dir)]
            (is (zero? hello-exit) (str "hello render failed\n" hello-out "\n" hello-err))
            (let [hello-dir (top-level-dist-dir dist)]
              (assert-greeting-rendered hello-dir)
              (is (= build-name (some-> hello-dir .getName)))))))
      (finally
        (delete-tree! dist)))))

(deftest hello-render-applies-bc-par-overrides
  (let [pkg-dir (System/getProperty "user.dir")
        dist (io/file pkg-dir ".dist")
        env (assoc (into {} (System/getenv)) "BC_PAR_NAME" "Alice")]
    (try
      (delete-tree! dist)
      (let [{:keys [exit out err]} (run-hello-render pkg-dir env)]
        (is (zero? exit) (str "hello render failed\n" out "\n" err))
        (assert-greeting-rendered (top-level-dist-dir dist) "Hello, Alice!"))
      (finally
        (delete-tree! dist)))))

(deftest package-validate-fails-for-placeholder-override
  (let [pkg-dir (System/getProperty "user.dir")
        env (assoc (into {} (System/getenv)) "BC_PAR_NAME" "REPLACE_ME")
        {:keys [exit out err]} (run-package pkg-dir "validate" env)]
    (is (= 1 exit) (str "validate should fail\n" out "\n" err))
    (is (str/includes? (str out "\n" err) "Validation failed"))))

(deftest top-level-validate-shortcut-is-not-exposed
  (let [pkg-dir (System/getProperty "user.dir")
        {:keys [exit out err]} (sh "bb" "run" "validate" :dir pkg-dir)]
    (is (= 1 exit) (str "top-level validate should fail\n" out "\n" err))
    (is (str/includes? err "Use `bb run package validate`."))))
