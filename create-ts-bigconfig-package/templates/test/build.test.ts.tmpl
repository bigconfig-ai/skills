import { spawnSync, type SpawnSyncReturns } from "node:child_process";
import { existsSync, mkdtempSync, readFileSync, readdirSync, rmSync, statSync } from "node:fs";
import { tmpdir } from "node:os";
import { join, resolve } from "node:path";
import { describe, expect, it } from "vitest";

const pkgDir = resolve(".");
const cli = join(pkgDir, "dist/src/cli.js");

function runRaw(cmd: string, args: string[], cwd: string, env = process.env): SpawnSyncReturns<string> {
  return spawnSync(cmd, args, { cwd, encoding: "utf8", env });
}

function expectRun(cmd: string, args: string[], cwd: string, env = process.env): void {
  const res = runRaw(cmd, args, cwd, env);
  expect(res.status, `${cmd} ${args.join(" ")} failed\nstdout:\n${res.stdout}\nstderr:\n${res.stderr}`).toBe(0);
}

function find(base: string, name: string): string | null {
  for (const entry of readdirSync(base)) {
    const p = join(base, entry);
    if (statSync(p).isDirectory()) {
      const hit = find(p, name);
      if (hit) return hit;
    } else if (entry === name) {
      return p;
    }
  }
  return null;
}

function topLevelDistDir(cwd: string): string {
  const dist = join(cwd, ".dist");
  expect(existsSync(dist)).toBe(true);
  const dirs = readdirSync(dist)
    .filter((entry) => statSync(join(dist, entry)).isDirectory())
    .sort();
  expect(dirs, "exactly one top-level .dist directory should be rendered").toHaveLength(1);
  return dirs[0]!;
}

function expectGreetingRendered(cwd: string, topLevelDir?: string, expected = "Hello, world!"): void {
  const dist = join(cwd, ".dist");
  expect(existsSync(dist)).toBe(true);
  const root = topLevelDir === undefined ? dist : join(dist, topLevelDir);
  const greeting = find(root, "greeting.txt");
  expect(greeting, "greeting.txt should be rendered under .dist").not.toBeNull();
  expect(readFileSync(greeting!, "utf8")).toContain(expected);
}

describe("__PKG_NAME__ package lifecycle", () => {
  it("runs validate, describe, and delete", () => {
    const tmp = mkdtempSync(join(tmpdir(), "__PKG_NAME__-"));
    try {
      for (const step of ["validate", "describe", "delete"]) {
        expectRun("node", [cli, "package", step], tmp);
      }
    } finally {
      rmSync(tmp, { recursive: true, force: true });
    }
  });

  it("renders the hello template for build and create", () => {
    for (const step of ["build", "create"]) {
      const tmp = mkdtempSync(join(tmpdir(), "__PKG_NAME__-"));
      try {
        expectRun("node", [cli, "package", step], tmp);
        expectGreetingRendered(tmp, topLevelDistDir(tmp));
      } finally {
        rmSync(tmp, { recursive: true, force: true });
      }
    }
  });

  it("uses the package build top-level .dist directory for hello render", () => {
    const buildTmp = mkdtempSync(join(tmpdir(), "__PKG_NAME__-build-"));
    const helloTmp = mkdtempSync(join(tmpdir(), "__PKG_NAME__-hello-"));
    try {
      expectRun("node", [cli, "package", "build"], buildTmp);
      const buildDir = topLevelDistDir(buildTmp);
      expectGreetingRendered(buildTmp, buildDir);

      expectRun("node", [cli, "hello", "render"], helloTmp);
      const helloDir = topLevelDistDir(helloTmp);
      expectGreetingRendered(helloTmp, helloDir);

      expect(helloDir).toBe(buildDir);
    } finally {
      rmSync(buildTmp, { recursive: true, force: true });
      rmSync(helloTmp, { recursive: true, force: true });
    }
  });

  it("applies BC_PAR overrides to hello render", () => {
    const tmp = mkdtempSync(join(tmpdir(), "__PKG_NAME__-hello-"));
    try {
      expectRun("node", [cli, "hello", "render"], tmp, { ...process.env, BC_PAR_NAME: "Alice" });
      expectGreetingRendered(tmp, topLevelDistDir(tmp), "Hello, Alice!");
    } finally {
      rmSync(tmp, { recursive: true, force: true });
    }
  });

  it("fails package validate when BC_PAR_NAME is REPLACE_ME", () => {
    const tmp = mkdtempSync(join(tmpdir(), "__PKG_NAME__-"));
    try {
      const res = runRaw("node", [cli, "package", "validate"], tmp, { ...process.env, BC_PAR_NAME: "REPLACE_ME" });
      expect(res.status).toBe(1);
      expect(`${res.stdout}\n${res.stderr}`).toContain("Validation failed");
    } finally {
      rmSync(tmp, { recursive: true, force: true });
    }
  });

  it("does not expose a top-level validate shortcut", () => {
    const tmp = mkdtempSync(join(tmpdir(), "__PKG_NAME__-"));
    try {
      const res = runRaw("node", [cli, "validate"], tmp);
      expect(res.status).toBe(1);
      expect(res.stderr).toContain("Unknown command: validate");
    } finally {
      rmSync(tmp, { recursive: true, force: true });
    }
  });
});
