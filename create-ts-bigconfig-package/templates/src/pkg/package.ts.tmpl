/** High-level package workflow and the `__PKG_NAME__ package` entry point. */
import {
  ENV,
  WF_BUILD_FN,
  WF_CREATE_FN,
  WF_DELETE_FN,
  WF_DESCRIBE_FN,
  WF_PARAMS,
  WF_VALIDATE_FN,
  type Opts,
  type StepFn,
} from "big-config";
import { createWorkflow } from "big-config/core";
import { createExitStepFn, createPrintErrorStepFn } from "big-config/step-fns";
import {
  createWorkflowStar,
  mergeParams,
  newPrefix,
  parseArgs,
  printStepFn,
  registerWorkflow,
  runSteps,
  selectGlobals,
} from "big-config/workflow";
import { describe as describeStep } from "./describe.js";
import { syncAliases, toBcOpts } from "./interop.js";
import { optsFn } from "./params.js";
import * as tools from "./tools.js";
import { validate } from "./validation.js";

const START = "__PKG_NAMESPACE__.package/start";
const END = "__PKG_NAMESPACE__.package/end";
const RENDER_PIPELINE_START = "__PKG_NAMESPACE__.package/start-render";
const RENDER_PIPELINE_END = "__PKG_NAMESPACE__.package/end-render";
const DELETE_PIPELINE_START = "__PKG_NAMESPACE__.package/start-delete";
const DELETE_PIPELINE_END = "__PKG_NAMESPACE__.package/end-delete";

export const stepFns: StepFn[] = [
  printStepFn,
  createExitStepFn(END),
  createPrintErrorStepFn(END),
];

// Register every tool stage so the pipeline can dispatch it by name.
registerWorkflow(tools.HELLO, tools.hello as any);

const RENDER_HELLO_PIPELINE = [
  tools.HELLO, ["render", optsFn],
];

/** `build`: render every stage without applying anything. */
export const build = createWorkflowStar({
  firstStep: RENDER_PIPELINE_START,
  lastStep: RENDER_PIPELINE_END,
  pipeline: RENDER_HELLO_PIPELINE,
});

/** `create`: safe demo create; render the same hello stage as build. */
export const create = createWorkflowStar({
  firstStep: RENDER_PIPELINE_START,
  lastStep: RENDER_PIPELINE_END,
  pipeline: RENDER_HELLO_PIPELINE,
});

/** `delete`: explicit no-op for the minimal package. */
export const deleteWorkflow = createWorkflowStar({
  firstStep: DELETE_PIPELINE_START,
  lastStep: DELETE_PIPELINE_END,
  pipeline: [],
});

/** Opts for direct tool commands: use the same prefix and params as `package build`. */
export function packageToolOpts(opts0: Opts = {}): Opts {
  const opts = toBcOpts(opts0);
  const globals = newPrefix(selectGlobals(opts), RENDER_PIPELINE_START);
  return syncAliases(optsFn({ ...opts, ...globals }));
}

const TOOL_OPTS_KEYS = [`${tools.HELLO}-opts`];

export function __PKG_VAR__(sfns: StepFn[], opts0: Opts): Opts {
  const opts = toBcOpts(opts0);
  const withFns: Opts = {
    [WF_CREATE_FN]: create,
    [WF_BUILD_FN]: build,
    [WF_DELETE_FN]: deleteWorkflow,
    [WF_VALIDATE_FN]: validate,
    [WF_DESCRIBE_FN]: describeStep,
    ...opts,
  };
  const merged = mergeParams(TOOL_OPTS_KEYS, opts[WF_PARAMS] ?? {}, withFns);
  const wf = createWorkflow({
    firstStep: START,
    wireFn: (step, resolvedStepFns) =>
      step === START
        ? [(o) => runSteps(resolvedStepFns, o), END]
        : [(o) => o, undefined],
  });
  return syncAliases(wf(sfns, merged));
}

export function __PKG_VAR__Star(args: string | string[], opts: Opts = {}): Opts {
  return __PKG_VAR__(stepFns, { ...parseArgs(args), [ENV]: "shell", ...toBcOpts(opts) });
}
