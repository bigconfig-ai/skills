#!/usr/bin/env node
/** Command-line entry point. */
import { realpathSync } from "node:fs";
import { resolve } from "node:path";
import { fileURLToPath } from "node:url";
import type { Opts } from "big-config";
import { bb } from "./__PKG_NAME__/options.js";
import { __PKG_VAR__Star } from "./__PKG_NAME__/package.js";
import { helloStar } from "./__PKG_NAME__/tools.js";

const PACKAGE_USAGE = "__PKG_NAME__ package <validate|describe|build|create|delete>...";

const HELP = `Usage: __PKG_NAME__ <command> [args...]

Commands:
  package <step>...  Run package lifecycle steps for the active profile.
                       __PKG_NAME__ package validate
                       __PKG_NAME__ package describe
                       __PKG_NAME__ package build
                       __PKG_NAME__ package create
                       __PKG_NAME__ package delete
  hello <args>       Render the hello tool. e.g. __PKG_NAME__ hello render

Notes:
  * When launched through \`run\`, the active profile comes from that script;
    otherwise it defaults to \`bb\` in src/__PKG_NAME__/options.ts.
  * Any param can be overridden with BC_PAR_* environment variables.`;

function die(...lines: string[]): never {
  for (const line of lines) console.error(line);
  process.exit(1);
}

export function main(argv: string[], opts: Opts = bb): void {
  const [command, ...rest] = argv;
  switch (command) {
    case undefined:
    case "help":
    case "--help":
    case "-h":
      console.log(HELP);
      return;
    case "package":
      if (rest.length === 0) die("Missing package step.", `Usage: ${PACKAGE_USAGE}`);
      __PKG_VAR__Star(rest, opts);
      return;
    case "hello":
      helloStar(rest, opts);
      return;
    default:
      die(`Unknown command: ${command}`, "", HELP);
  }
}

function isMainModule(): boolean {
  const entry = process.argv[1];
  if (!entry) return false;
  const modulePath = fileURLToPath(import.meta.url);
  try {
    return realpathSync(entry) === realpathSync(modulePath);
  } catch {
    return resolve(entry) === modulePath;
  }
}

if (isMainModule()) {
  main(process.argv.slice(2));
}
