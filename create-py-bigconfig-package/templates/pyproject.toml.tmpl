[project]
name = "__PKG_NAME__"
version = "1.0.0"
description = "__PKG_DESC__"
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
  "__BIG_CONFIG_REF__",
]

[project.scripts]
__PKG_NAME__ = "__PKG_MODULE__.cli:main"

[dependency-groups]
dev = [
  "pytest>=8.0",
]

[tool.hatch.metadata]
allow-direct-references = true

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/__PKG_MODULE__"]
force-include = { "src/resources" = "src/resources" }

[tool.hatch.build.targets.sdist]
include = ["src", "tests", "pyproject.toml", "README.md", "run"]

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src"]
